NODE_ENV=development
PORT=3000
APP_RUNTIME=server
APP_CORS_ENABLED=true
APP_CORS_ORIGINS=*
APP_CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_CORS_CREDENTIALS=true
APP_BASE_DOMAIN=localhost
APP_GLOBAL_PREFIX=
APP_SHUTDOWN_TIMEOUT_MS=15000
DEFAULT_TENANT_ID=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shule_hub
DATABASE_RUNTIME_ROLE=shule_hub_runtime
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=5000
DATABASE_CONNECT_MAX_RETRIES=10
DATABASE_CONNECT_RETRY_DELAY_MS=2000
REDIS_URL=rediss://default:replace-with-upstash-token@your-upstash-host.upstash.io:6379
REDIS_CONNECT_TIMEOUT_MS=10000
QUEUE_PREFIX=shule-hub
QUEUE_DEFAULT_JOB_ATTEMPTS=3
QUEUE_REMOVE_ON_COMPLETE=1000
QUEUE_REMOVE_ON_FAIL=5000
JWT_SECRET=replace-with-a-long-random-string
JWT_ISSUER=shule-hub-api
JWT_AUDIENCE=shule-hub-web
JWT_ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
JWT_REFRESH_TOKEN_SECRET=replace-with-a-long-random-string
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
BCRYPT_SALT_ROUNDS=12
SECURITY_PII_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_MAX_REQUESTS=120
SECURITY_AUTH_RATE_LIMIT_MAX_REQUESTS=20
SECURITY_MPESA_CALLBACK_RATE_LIMIT_MAX_REQUESTS=60
SECURITY_FRAUD_HIGH_VALUE_AMOUNT_MINOR=5000000
SECURITY_FRAUD_VELOCITY_WINDOW_SECONDS=900
SECURITY_FRAUD_VELOCITY_THRESHOLD=5
SECURITY_FRAUD_CROSS_ACCOUNT_THRESHOLD=3
SECURITY_FRAUD_REPEATED_AMOUNT_THRESHOLD=3
SECURITY_FRAUD_CALLBACK_FAILURE_THRESHOLD=3
FINANCE_IDEMPOTENCY_TTL_SECONDS=86400
BILLING_ACCESS_CACHE_TTL_SECONDS=60
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=replace-with-daraja-consumer-key
MPESA_CONSUMER_SECRET=replace-with-daraja-consumer-secret
MPESA_SHORT_CODE=174379
MPESA_PASSKEY=replace-with-daraja-passkey
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_CALLBACK_URL=https://tenant.localhost:3000/payments/mpesa/callback
MPESA_CALLBACK_SECRET=replace-with-a-long-random-callback-secret
MPESA_CALLBACK_TIMESTAMP_TOLERANCE_SECONDS=300
MPESA_REPLAY_WINDOW_SECONDS=86400
MPESA_QUEUE_NAME=payments-mpesa
MPESA_REQUEST_TIMEOUT_MS=15000
MPESA_QUEUE_CONCURRENCY=5
MPESA_PAYMENT_INTENT_EXPIRY_SECONDS=1800
MPESA_STALE_INTENT_SWEEP_BATCH_SIZE=100
MPESA_LEDGER_DEBIT_ACCOUNT_CODE=1100-MPESA-CLEARING
MPESA_LEDGER_CREDIT_ACCOUNT_CODE=2100-CUSTOMER-DEPOSITS
EVENTS_QUEUE_NAME=erp-events
EVENTS_DISPATCHER_ENABLED=true
EVENTS_WORKER_ENABLED=true
EVENTS_DISPATCHER_INTERVAL_MS=1000
EVENTS_DISPATCHER_BATCH_SIZE=100
EVENTS_STALE_PROCESSING_AFTER_MS=30000
EVENTS_RETRY_DELAY_MS=5000
EVENTS_MAX_ATTEMPTS=25
OBSERVABILITY_SLO_WINDOW_SECONDS=900
OBSERVABILITY_SLO_BACKGROUND_ENABLED=true
OBSERVABILITY_SLO_EVALUATION_INTERVAL_SECONDS=30
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_DOMAIN=localhost:3000
