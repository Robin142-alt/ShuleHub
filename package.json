{
  "name": "shule-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register apps/api/src/main.ts",
    "start:events-worker": "node dist/apps/api/src/events-worker.js",
    "start:events-worker:dev": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/events-worker.ts",
    "start:payments-worker": "node dist/apps/api/src/payments-worker.js",
    "start:payments-worker:dev": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/payments-worker.ts",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:start": "npm --prefix apps/web run start",
    "web:lint": "npm --prefix apps/web run lint",
    "web:test:design": "npm --prefix apps/web run test:design",
    "web:test:design:e2e": "npm --prefix apps/web run test:design:e2e",
    "web:test:design:e2e:list": "npm --prefix apps/web run test:design:e2e:list",
    "docker:compose:up": "docker compose up --build",
    "docker:compose:down": "docker compose down -v",
    "deploy:railway:prepare:api": "node scripts/prepare-railway-config.mjs deploy/railway/api.railway.json",
    "deploy:railway:prepare:payments-worker": "node scripts/prepare-railway-config.mjs deploy/railway/payments-worker.railway.json",
    "deploy:railway:prepare:events-worker": "node scripts/prepare-railway-config.mjs deploy/railway/events-worker.railway.json",
    "vercel:dev": "npx vercel dev",
    "deploy:vercel": "npx vercel --prod",
    "seed": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/scripts/seed.ts",
    "seed:tenant": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/scripts/seed.ts",
    "queue:payments:enqueue:test": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/scripts/enqueue-payment-job.ts",
    "queue:payments:verify:test": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/src/scripts/verify-payment-processing.ts",
    "test": "npm run build && node --test dist/apps/api/src/database/database.test.js dist/apps/api/src/auth/auth.test.js dist/apps/api/src/modules/finance/finance.test.js dist/apps/api/src/modules/payments/payments.test.js dist/apps/api/src/modules/events/events.test.js dist/apps/api/src/modules/sync/sync.test.js dist/apps/api/src/modules/students/students.test.js dist/apps/api/src/modules/billing/billing.test.js dist/apps/api/src/modules/observability/observability.test.js dist/apps/api/src/modules/security/security.test.js dist/apps/api/src/modules/library/library.test.js",
    "test:tenant-isolation": "jest --config jest.integration.config.js --runInBand apps/api/test/tenant-isolation.integration-spec.ts",
    "test:finance-integrity": "jest --config jest.integration.config.js --runInBand apps/api/test/finance-integrity.integration-spec.ts",
    "test:mpesa-adversarial": "jest --config jest.integration.config.js --runInBand apps/api/test/mpesa-adversarial.integration-spec.ts",
    "test:mpesa-network-conditions": "jest --config jest.integration.config.js --runInBand apps/api/test/mpesa-network-conditions.integration-spec.ts",
    "test:race-conditions": "jest --config jest.integration.config.js --runInBand apps/api/test/race-conditions.integration-spec.ts",
    "test:sync-consistency": "jest --config jest.integration.config.js --runInBand apps/api/test/sync-consistency.integration-spec.ts",
    "test:auth-security": "jest --config jest.integration.config.js --runInBand apps/api/test/auth-security.integration-spec.ts",
    "test:api-consistency": "jest --config jest.integration.config.js --runInBand apps/api/test/api-consistency.integration-spec.ts",
    "test:billing-correctness": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/support/run-integration-with-local-postgres.ts jest --config jest.integration.config.js --runInBand apps/api/test/billing-correctness.integration-spec.ts",
    "test:config-driven": "jest --config jest.integration.config.js --runInBand apps/api/test/config-driven.integration-spec.ts",
    "test:fraud-scenarios": "jest --config jest.integration.config.js --runInBand apps/api/test/fraud-scenarios.integration-spec.ts",
    "test:workflows": "jest --config jest.integration.config.js --runInBand apps/api/test/workflow.integration-spec.ts",
    "test:observability": "jest --config jest.integration.config.js --runInBand apps/api/test/observability.integration-spec.ts",
    "test:chaos": "jest --config jest.integration.config.js --runInBand apps/api/test/chaos.integration-spec.ts",
    "test:gameday": "jest --config jest.integration.config.js --runInBand apps/api/test/gameday.integration-spec.ts",
    "test:migrations": "jest --config jest.integration.config.js --runInBand apps/api/test/migrations.integration-spec.ts",
    "test:disaster-recovery": "jest --config jest.integration.config.js --runInBand apps/api/test/disaster-recovery.integration-spec.ts",
    "test:backup-integrity": "jest --config jest.integration.config.js --runInBand apps/api/test/backup-integrity.integration-spec.ts",
    "test:compliance": "jest --config jest.integration.config.js --runInBand apps/api/test/compliance.integration-spec.ts",
    "test:deployment-pipeline": "jest --config jest.integration.config.js --runInBand apps/api/test/deployment-pipeline.integration-spec.ts",
    "load:soak": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/soak-load.ts",
    "load:tenant-scale": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/tenant-scale.load.ts",
    "test:financial-reconciliation": "jest --config jest.integration.config.js --runInBand apps/api/test/financial-reconciliation.integration-spec.ts",
    "test:financial-truth": "jest --config jest.integration.config.js --runInBand apps/api/test/financial-truth.integration-spec.ts",
    "test:cost-performance": "jest --config jest.integration.config.js --runInBand apps/api/test/cost-performance.integration-spec.ts",
    "load:financial-truth": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/financial-truth-load.ts",
    "load:race-conditions": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/race-load.ts",
    "load:mpesa-network-failures": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/mpesa-network-failure-injection.ts",
    "load:kenyan-school:generate": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/kenyan-school-generate.ts",
    "load:kenyan-school": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/kenyan-school-load.ts",
    "load:cost-performance": "node -r ts-node/register/transpile-only -r tsconfig-paths/register apps/api/test/cost-performance.load.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pg-format": "^1.0.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
